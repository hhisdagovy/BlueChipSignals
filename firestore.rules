rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ── Public read collections ─────────────────────────────────────────────
    // roadmap_milestones: anyone can read, only admins can write
    match /roadmap_milestones/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // site_settings: anyone can read, only admins can write
    match /site_settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // settings: dashboard config (maintenance mode, signal channel status, announcements)
    // must be readable before auth resolves, so public read is intentional
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Authenticated-only collections ──────────────────────────────────────
    // signals: members must be signed in to read
    match /signals/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // users: each user can read/write their own doc; admins can read all
    match /users/{userId} {
      allow read:  if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    // ── Catch-all: deny everything else ────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
