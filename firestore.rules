rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }
    function isSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    function changedKeysAreAllowedForSelfProfile() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'firstName',
        'lastName',
        'displayName',
        'phone',
        'tradingExperience',
        'primaryInterest',
        'termsAccepted',
        'termsAcceptedDate',
        'lastLogin',
        'joinedDate',
        'setupCompleted',
        'profileComplete'
      ]);
    }
    function changedProfileFieldsHaveValidTypes() {
      return (
        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['firstName']) ||
          (request.resource.data.keys().hasAll(['firstName']) && request.resource.data.firstName is string)) &&
        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['lastName']) ||
          (request.resource.data.keys().hasAll(['lastName']) && request.resource.data.lastName is string)) &&
        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['displayName']) ||
          (request.resource.data.keys().hasAll(['displayName']) && request.resource.data.displayName is string)) &&
        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['phone']) ||
          (request.resource.data.keys().hasAll(['phone']) && request.resource.data.phone is string)) &&
        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['tradingExperience']) ||
          (request.resource.data.keys().hasAll(['tradingExperience']) && request.resource.data.tradingExperience is string)) &&
        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['primaryInterest']) ||
          (request.resource.data.keys().hasAll(['primaryInterest']) && request.resource.data.primaryInterest is string)) &&
        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['termsAcceptedDate']) ||
          (request.resource.data.keys().hasAll(['termsAcceptedDate']) && request.resource.data.termsAcceptedDate is string)) &&
        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['lastLogin']) ||
          (request.resource.data.keys().hasAll(['lastLogin']) && request.resource.data.lastLogin is string)) &&
        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['joinedDate']) ||
          (request.resource.data.keys().hasAll(['joinedDate']) && request.resource.data.joinedDate is string))
      );
    }
    function joinedDateIsImmutableAfterSet() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['joinedDate']) ||
        !resource.data.keys().hasAny(['joinedDate']) ||
        request.resource.data.joinedDate == resource.data.joinedDate;
    }
    function termsAcceptanceIsValid() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['termsAccepted']) ||
        (request.resource.data.keys().hasAll(['termsAccepted']) &&
          request.resource.data.termsAccepted is bool &&
          request.resource.data.termsAccepted == true);
    }
    function setupFlagsAreValid() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['setupCompleted', 'profileComplete']) ||
        (
          request.resource.data.keys().hasAll(['setupCompleted', 'profileComplete']) &&
          request.resource.data.setupCompleted is bool &&
          request.resource.data.profileComplete is bool &&
          request.resource.data.setupCompleted == request.resource.data.profileComplete &&
          (!(resource.data.keys().hasAny(['setupCompleted']) && resource.data.setupCompleted == true) ||
            request.resource.data.setupCompleted == true) &&
          (!(resource.data.keys().hasAny(['profileComplete']) && resource.data.profileComplete == true) ||
            request.resource.data.profileComplete == true) &&
          (!(request.resource.data.setupCompleted == true) ||
            (request.resource.data.keys().hasAll(['termsAccepted']) && request.resource.data.termsAccepted == true))
        );
    }
    function isSafeSelfUserUpdate(userId) {
      return isSelf(userId) &&
        changedKeysAreAllowedForSelfProfile() &&
        changedProfileFieldsHaveValidTypes() &&
        joinedDateIsImmutableAfterSet() &&
        termsAcceptanceIsValid() &&
        setupFlagsAreValid();
    }

    // ── Public read collections ─────────────────────────────────────────────
    // roadmap_milestones: anyone can read, only admins can write
    match /roadmap_milestones/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // faq_items: anyone can read, only admins can write
    match /faq_items/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // site_settings: anyone can read, only admins can write
    match /site_settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // site_config: public read for stats (signal channels, educational guides, etc.)
    match /site_config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // settings: dashboard config (maintenance mode, signal channel status, announcements)
    // must be readable before auth resolves, so public read is intentional
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Authenticated-only collections ──────────────────────────────────────
    // signals: members must be signed in to read
    match /signals/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // users: each user can read/write their own doc; admins can read all
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || isSafeSelfUserUpdate(userId);
    }

    // canonical fulfillment collections: admins only from console / backend
    match /orders/{docId} {
      allow read, write: if isAdmin();
    }

    match /entitlements/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    match /channel_access/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    match /provisioning_events/{docId} {
      allow read, write: if isAdmin();
    }

    // ── Catch-all: deny everything else ────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
